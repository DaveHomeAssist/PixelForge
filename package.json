{
  "name": "pixelforge",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <25",
    "npm": ">=10"
  },
  "scripts": {
    "preinstall": "node scripts/verify-runtime.mjs --require-npm",
    "verify:runtime": "node scripts/verify-runtime.mjs",
    "dev": "node scripts/verify-runtime.mjs && vite",
    "build": "node scripts/verify-runtime.mjs && vite build",
    "preview": "node scripts/verify-runtime.mjs && vite preview",
    "lint": "node scripts/verify-runtime.mjs && eslint src eslint.config.js vitest.config.js vite.config.js",
    "test": "node scripts/verify-runtime.mjs && vitest run",
    "test:watch": "node scripts/verify-runtime.mjs && vitest",
    "budget": "node scripts/check-bundle-size.mjs",
    "ci": "node scripts/verify-runtime.mjs && npm run lint && npm run test && npm run build && npm run budget"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.4",
    "vitest-canvas-mock": "^1.1.4"
  }
}
